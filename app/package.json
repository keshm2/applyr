{
  "name": "ares-apply",
  "version": "0.1.0",
  "description": "Terminal UI overlay for the Ares job-application agent — setup wizard, run, status, review-queue triage, and history over the Python core.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ares": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/cli.js status"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.0"
  }
}
